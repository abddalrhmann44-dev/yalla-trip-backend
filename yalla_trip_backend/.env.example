# ── App ───────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://yalla:yalla_secret@db:5432/yalla_trip
DATABASE_URL_SYNC=postgresql://yalla:yalla_secret@db:5432/yalla_trip

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Firebase ──────────────────────────────────────────────
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ── AWS S3 ────────────────────────────────────────────────
AWS_ACCESS_KEY=your-access-key
AWS_SECRET_KEY=your-secret-key
AWS_BUCKET_NAME=yalla-trip-media
AWS_REGION=eu-south-1

# ── Fawry Payment ────────────────────────────────────────
FAWRY_MERCHANT_CODE=your-merchant-code
FAWRY_SECRET_KEY=your-secret-key
FAWRY_BASE_URL=https://atfawry.fawrystaging.com

# ── FCM Push Notifications ───────────────────────────────
FCM_SERVER_KEY=your-fcm-server-key

# ── JWT ───────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
JWT_REFRESH_EXPIRE_DAYS=30

# ── Rate Limit ────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100

# ── Platform ──────────────────────────────────────────────
PLATFORM_FEE_PERCENT=8.0
