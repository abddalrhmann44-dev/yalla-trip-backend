# ══════════════════════════════════════════════════════════════
#  Talaa Backend — Environment Variables
#
#  IMPORTANT: On Railway, set these in the Dashboard → Variables tab.
#  Locally, copy this file to `.env` and fill in the values.
#  When DATABASE_URL / REDIS_URL are left blank, the app falls back
#  to localhost defaults (Docker Compose local dev stack).
# ══════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────
APP_ENV=development              # Railway: "production"
DEBUG=true                       # Railway: "false"
SECRET_KEY=change-me-to-a-random-64-char-string
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
# Railway example:
# ALLOWED_ORIGINS=https://talaa.app,https://yalla-trip-backend-production.up.railway.app

# ── Database ──────────────────────────────────────────────
# Leave blank for local dev (falls back to localhost:5432).
# Railway: set to the Postgres internal URL provided by the plugin.
# Accepts postgres://, postgresql://, or postgresql+asyncpg:// — all are
# normalised automatically.
DATABASE_URL=
# DATABASE_URL_SYNC is auto-derived; only set if you need a custom sync URL.

# ── Redis ─────────────────────────────────────────────────
# Leave blank for local dev (falls back to localhost:6379).
# Railway: set to the Redis internal URL provided by the plugin.
REDIS_URL=

# ── Firebase ──────────────────────────────────────────────
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ── AWS S3 ────────────────────────────────────────────────
AWS_ACCESS_KEY=your-access-key
AWS_SECRET_KEY=your-secret-key
AWS_BUCKET_NAME=yalla-trip-media
AWS_REGION=eu-south-1

# ── Fawry Payment ────────────────────────────────────────
FAWRY_MERCHANT_CODE=your-merchant-code
FAWRY_SECRET_KEY=your-secret-key
FAWRY_BASE_URL=https://atfawry.fawrystaging.com

# ── Paymob Payment (cards + wallets) ─────────────────────
# Get these from https://accept.paymob.com/portal
PAYMOB_API_KEY=your-admin-api-key
PAYMOB_HMAC_SECRET=your-hmac-secret
PAYMOB_IFRAME_ID=0
PAYMOB_INTEGRATION_CARD=0
PAYMOB_INTEGRATION_WALLET=0

# ── Payments mock mode ────────────────────────────────────
PAYMENTS_MOCK_MODE=false

# ── App base URL (for absolute links in mock checkout, etc.) ──
# Railway: https://yalla-trip-backend-production.up.railway.app
APP_BASE_URL=

# ── WhatsApp Cloud API (OTP delivery) ─────────────────────
# Get these from https://developers.facebook.com → WhatsApp product.
# Leave blank to fall back to console logging (dev).
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_OTP_TEMPLATE_NAME=talaa_otp
# Fixed test code for TestFlight / QA (leave blank in production)
OTP_TEST_CODE=123456

# ── FCM Push Notifications ───────────────────────────────
FCM_SERVER_KEY=your-fcm-server-key

# ── Sentry Error Tracking (leave blank to disable) ───────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_RELEASE=

# ── JWT ───────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
JWT_REFRESH_EXPIRE_DAYS=30

# ── Rate Limit ────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100

# ── Platform ──────────────────────────────────────────────
PLATFORM_FEE_PERCENT=10.0

# ── Disbursement (Wave 26) ────────────────────────────────
# Use "mock" for local dev; flip to "kashier" once the contract is
# signed and the credentials below are populated.
DISBURSE_PROVIDER=mock
KASHIER_DISBURSE_BASE_URL=https://api.kashier.io
KASHIER_DISBURSE_MERCHANT_ID=
KASHIER_DISBURSE_API_KEY=
KASHIER_DISBURSE_SECRET=
DISBURSE_SLA_HOURS=48

# ── Admin bootstrap ───────────────────────────────────────
# Comma-separated emails that become admin on first login and are
# auto-promoted on subsequent logins (one-way: never auto-demote).
# Works with any Firebase provider (email/password, Google Sign-In, phone).
# Keep this list very small and rotate when ownership changes.
ADMIN_EMAILS=qaran12121@gmail.com,abdalrhamnmohamed4@gmail.com
