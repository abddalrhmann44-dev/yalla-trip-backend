# ═══════════════════════════════════════════════════════════
#  Talaa API — production .env template
#
#  Copy to ``.env.prod`` and fill in real values.  Never commit
#  the populated file.  All secrets below are mandatory; leave
#  the tunables at their defaults unless you have a reason.
# ═══════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────
APP_ENV=production
DEBUG=false
# Generate via: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE-ME
ALLOWED_ORIGINS=["https://app.talaa.com","https://talaa.com"]

# ── Database ───────────────────────────────────────────────
# Must match the POSTGRES_* vars below — compose substitutes them into
# the postgres container *and* the URL we give to SQLAlchemy.
POSTGRES_USER=talaa
POSTGRES_PASSWORD=CHANGE-ME-STRONG
POSTGRES_DB=talaa
DATABASE_URL=postgresql+asyncpg://talaa:CHANGE-ME-STRONG@db:5432/talaa
DATABASE_URL_SYNC=postgresql://talaa:CHANGE-ME-STRONG@db:5432/talaa

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_MAX_MEMORY=256mb

# ── Firebase service-account JSON (one line, escape quotes) ─
FIREBASE_CREDENTIALS_JSON={}

# ── AWS S3 media bucket ────────────────────────────────────
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_BUCKET_NAME=talaa-media-prod
AWS_REGION=eu-south-1

# ── Paymob ─────────────────────────────────────────────────
PAYMOB_API_KEY=
PAYMOB_HMAC_SECRET=
PAYMOB_IFRAME_ID=
PAYMOB_INTEGRATION_CARD=
PAYMOB_INTEGRATION_WALLET=

# ── Fawry (optional fallback) ──────────────────────────────
FAWRY_MERCHANT_CODE=
FAWRY_SECRET_KEY=
FAWRY_BASE_URL=https://atfawry.fawrystaging.com

# ── FCM ────────────────────────────────────────────────────
FCM_SERVER_KEY=

# ── Sentry ─────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_RELEASE=talaa-api@1.0.0

# ── JWT / rate limit ───────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30
RATE_LIMIT_PER_MINUTE=120

# ── Platform ───────────────────────────────────────────────
PLATFORM_FEE_PERCENT=10.0
ADMIN_EMAILS=ops@talaa.com

# ── Resource limits (compose) ──────────────────────────────
API_WORKERS=4
API_CPU_LIMIT=2.0
API_MEM_LIMIT=1g
DB_CPU_LIMIT=2.0
DB_MEM_LIMIT=2g
